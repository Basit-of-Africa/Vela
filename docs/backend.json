
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user data including roles and permissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Admin", "Staff"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "isProvisioned": { "type": "boolean" },
        "setupCompleted": { "type": "boolean" },
        "businessName": { "type": "string" },
        "industry": { "type": "string" }
      },
      "required": ["userId", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A client or lead in the CRM.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the business owner/tenant." },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive"] },
        "totalValue": { "type": "number" },
        "lastContact": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "status"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential deal in the sales pipeline.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "customerName": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string", "enum": ["Discovery", "Proposal", "Negotiation", "Closed Won", "Closed Lost"] },
        "probability": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "customerName", "value", "stage"]
    },
    "Project": {
      "title": "Project",
      "description": "A post-sale delivery project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Hold", "Completed"] },
        "progress": { "type": "number" },
        "budget": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "currentMilestone": { "type": "string" }
      },
      "required": ["userId", "title", "status", "customerName"]
    },
    "Activity": {
      "title": "Activity",
      "description": "System-wide audit log of business operations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "module": { "type": "string", "enum": ["CRM", "HR", "Finance", "Operations", "System"] },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string", "enum": ["info", "success", "warning"] }
      },
      "required": ["userId", "module", "action", "timestamp"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A touchpoint with a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "type": { "type": "string", "enum": ["Call", "Email", "Meeting", "Note"] },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "content", "date"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A company team member.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "On Leave", "Terminated"] },
        "joinDate": { "type": "string", "format": "date" }
      },
      "required": ["userId", "name", "role", "email", "status"]
    },
    "Integration": {
      "title": "Integration",
      "description": "External tool connection settings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "lastSync": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "System users and roles." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Business customers." },
    "/leads/{leadId}": { "schema": "Lead", "description": "Sales deals." },
    "/projects/{projectId}": { "schema": "Project", "description": "Active delivery projects." },
    "/activities/{activityId}": { "schema": "Activity", "description": "Unified system audit logs." },
    "/integrations/{integrationId}": { "schema": "Integration", "description": "Tenant tool integrations." }
  }
}
