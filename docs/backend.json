
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user data including roles and permissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Admin", "Staff"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "isProvisioned": { "type": "boolean" }
      },
      "required": ["userId", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A client or lead in the CRM.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the business owner/tenant." },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive"] },
        "totalValue": { "type": "number" },
        "lastContact": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "status"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential deal in the sales pipeline.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "customerName": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string", "enum": ["Discovery", "Proposal", "Negotiation", "Closed Won", "Closed Lost"] },
        "probability": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "customerName", "value", "stage"]
    },
    "Project": {
      "title": "Project",
      "description": "A post-sale delivery project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Hold", "Completed"] },
        "progress": { "type": "number" },
        "budget": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["userId", "title", "status", "customerName"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A touchpoint with a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "type": { "type": "string", "enum": ["Call", "Email", "Meeting", "Note"] },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "content", "date"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A company team member.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "On Leave", "Terminated"] },
        "joinDate": { "type": "string", "format": "date" }
      },
      "required": ["userId", "name", "role", "email", "status"]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "An employee time-off request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "type": { "type": "string", "enum": ["Annual", "Sick", "Maternity", "Unpaid"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "reason": { "type": "string" }
      },
      "required": ["userId", "employeeId", "type", "startDate", "endDate", "status"]
    },
    "HRQuery": {
      "title": "HR Query",
      "description": "An internal helpdesk ticket.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "employeeName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "employeeName", "subject", "message", "status", "priority"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["userId", "date", "type", "category", "amount"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled event or meeting.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "title"]
    },
    "Settings": {
      "title": "System Settings",
      "description": "Tenant-level configuration for automation and AI behavior.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "autoOnboarding": { "type": "boolean" },
        "autoProjectCreation": { "type": "boolean" },
        "healthThreshold": { "type": "number" },
        "aiReportTone": { "type": "string" },
        "trainingPassMark": { "type": "number" },
        "defaultProjectDuration": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "System users and roles." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Business customers." },
    "/leads/{leadId}": { "schema": "Lead", "description": "Sales deals." },
    "/projects/{projectId}": { "schema": "Project", "description": "Active delivery projects." },
    "/interactions/{interactionId}": { "schema": "Interaction", "description": "Client interaction logs." },
    "/employees/{employeeId}": { "schema": "Employee", "description": "Staff members." },
    "/leaveRequests/{requestId}": { "schema": "LeaveRequest", "description": "Time-off requests." },
    "/hrQueries/{queryId}": { "schema": "HRQuery", "description": "Helpdesk tickets." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records." },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "Calendar appointments." },
    "/settings/{userId}": { "schema": "Settings", "description": "Tenant configuration." }
  }
}
